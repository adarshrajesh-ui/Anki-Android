<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools" tools:ignore="DuplicateCrowdInStrings">
    <color name="theme_dark_primary">#3d3d3d</color>
    <color name="theme_dark_primary_dark">@color/material_grey_900</color>
    <color name="theme_dark_primary_light">@color/material_grey_800</color>
    <color name="theme_dark_primary_text">@color/white</color>
    <color name="theme_dark_secondary_text">#b2ffffff</color>
    <color name="theme_dark_row_current">#393939</color>
    <color name="theme_dark_drawer_row_current">#33999999</color>
    <color name="theme_dark_drawer_item">#DEFFFFFF</color>

    <style name="Base.Theme.Dark" parent="@style/Theme.Material3.Dark.NoActionBar">
        <!-- Android colors -->
        <!-- CFA fork (dark-mode brand parity): colorPrimary/colorAccent drive the
             app's interactive tints (switches, checkboxes, sliders, activated
             widgets, text-button labels, links). They shipped stock-AnkiDroid
             light-blue in dark mode while the light theme is CFA-branded. Navy is
             too dark to read on the #303030 dark surface, so dark mode uses the
             brand's warm accent-on-navy tint (#F0894A, 5.25:1 on #303030 / 8.4:1
             on black — clears WCAG AA), the same warm identity the FAB already
             uses in dark mode. -->
        <item name="colorPrimary">@color/cfa_accent_on_navy</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryDark">@color/theme_dark_primary_dark</item>
        <item name="colorSurface">?android:colorBackground</item>
        <item name="colorAccent">@color/cfa_accent_on_navy</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorPrimaryContainer">@color/white</item> <!-- Switch thumb color when disabled and being pressed -->
        <item name="colorOnPrimaryContainer">@color/white</item> <!-- FAB icons -->

        <item name="android:textColor">@color/text_color_dark</item>
        <item name="android:textColorSecondary">@color/text_color_secondary_dark</item>
        <item name="android:colorBackground">@color/material_theme_grey</item>
        <item name="android:windowBackground">@color/material_theme_grey</item>
        <!-- CFA fork: the tonal secondary container (selected chips/sheets) was a
             stock blue-grey (#3C5A6E); retone to the brand navy so selected states
             read on-brand. White onSecondaryContainer text stays high-contrast on
             navy. -->
        <item name="colorSecondaryContainer">@color/cfa_navy</item>
        <item name="colorOnSecondaryContainer">@color/white</item>

        <item name="colorSurfaceContainerHighest">?attr/colorSurfaceContainer</item>
        <item name="colorSurfaceContainerHigh">#424C54</item>
        <!-- CFA fork: the elevated surface container was a 6% stock-blue tint
             (#0F42A5F5), the dark-mode twin of the light-theme blue leak; retone to
             a 6% brand-navy tint so elevated surfaces carry no stock-Anki blue. -->
        <item name="colorSurfaceContainer">#0F122B46</item>
        <item name="colorSurfaceContainerLow">?android:attr/colorBackground</item>
        <!-- Widget colors -->
        <item name="widgetColorActivated">?attr/colorAccent</item>
        <item name="preferenceCategoryTitleTextColor">?attr/colorAccent</item>
        <!-- Navigation drawer -->
        <item name="navDrawerItemColor">@color/drawer_item_text_dark</item>
        <item name="navDrawerItemBackgroundColor">@drawable/drawer_item_background_dark</item>
        <!-- Menu -->
        <item name="actionOverflowMenuStyle">@style/OverflowMenuStyle</item>
        <item name="popupMenuStyle">@style/PopupMenuStyle</item>
        <item name="spinnerStyle">@style/SpinnerStyle</item>
        <!-- Action bar styles -->
        <item name="appBarColor">@color/theme_dark_primary</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="actionBarTextColor">@color/white</item>
        <item name="actionBarPopupTextColor">@color/theme_dark_primary_text</item>
        <item name="actionModeBackground">@color/theme_dark_primary</item>
        <!-- Tab layout -->
        <item name="tabLayoutBackgroundColor">@color/theme_dark_primary</item>
        <!-- CFA fork: active tab icon was stock light-blue; retone to the warm
             brand accent so the selected tab reads on-brand on the grey tab bar. -->
        <item name="tabActiveIconColor">@color/cfa_accent_on_navy</item>
        <!-- Deck list colors and divider -->
        <item name="currentDeckBackground">@drawable/item_background_selected</item>
        <item name="currentDeckBackgroundColor">@color/theme_dark_row_current</item>
        <item name="focusedRowBackgroundColor">@color/theme_dark_row_current</item>
        <!-- CFA fork: filtered/dynamic deck names (the curated CFA study decks) were
             stock light-blue; retone to the warm brand accent so the dark deck list
             is one cohesive branded list (light theme uses navy on its white list). -->
        <item name="dynDeckColor">@color/cfa_accent_on_navy</item>
        <item name="deckDivider">@drawable/divider_dark</item>
        <item name="expandRef">@drawable/ic_chevron_right_white</item>
        <item name="collapseRef">@drawable/ic_expand_more_white</item>
        <!-- Count colors -->
        <!-- CFA fork: the "new" count was stock indigo-blue; retone to the warm
             brand accent (learn = red / review = green kept as the learned Anki
             affordance), mirroring the light theme's navy "new" count. -->
        <item name="newCountColor">@color/cfa_accent_on_navy</item>
        <item name="learnCountColor">@color/material_red_200</item>
        <item name="reviewCountColor">@color/material_green_200</item>
        <item name="buryCountColor">@color/disabled_gray_dark</item>
        <item name="zeroCountColor">#404040</item>
        <!-- Study Screen colors -->
        <item name="showAnswerButtonBackground">#22333f</item>
        <item name="againButtonBackground">@color/material_red_800</item>
        <item name="hardButtonBackground">@color/material_blue_grey_800</item>
        <item name="goodButtonBackground">@color/material_green_800</item>
        <item name="easyButtonBackground">@color/material_light_blue_800</item>
        <item name="topBarColor">@color/theme_dark_primary_light</item>
        <item name="maxTimerColor">@color/material_red_300</item>
        <item name="answerButtonTextColor">@color/white</item>
        <item name="againButtonTextColor">@color/white</item>
        <item name="hardButtonTextColor">@color/white</item>
        <item name="goodButtonTextColor">@color/white</item>
        <item name="easyButtonTextColor">@color/white</item>

        <item name="alternativeBackgroundColor">#2a2a2a</item>
        <item name="againTextColor">@color/material_red_200</item>
        <item name="hardTextColor">@color/material_orange_200</item>
        <item name="goodTextColor">@color/material_light_green_200</item>
        <item name="easyTextColor">@color/material_light_blue_A100</item>
        <item name="againBackgroundColor">#462828</item>
        <item name="hardBackgroundColor">#4e3122</item>
        <item name="goodBackgroundColor">#2c3b2c</item>
        <item name="easyBackgroundColor">#223946</item>
        <item name="againIconColor">?againTextColor</item>
        <item name="hardIconColor">?hardTextColor</item>
        <item name="goodIconColor">?goodTextColor</item>
        <item name="easyIconColor">?easyTextColor</item>
        <!-- Study Screen button drawables -->
        <item name="showAnswerColor">@color/material_blue_grey_800</item>
        <item name="againButtonRef">@drawable/footer_button_again_dark</item>
        <item name="hardButtonRef">@drawable/footer_button_hard_dark</item>
        <item name="goodButtonRef">@drawable/footer_button_good_dark</item>
        <item name="easyButtonRef">@drawable/footer_button_easy_dark</item>
        <item name="againButtonRippleRef">@drawable/footer_button_ripple</item>
        <item name="hardButtonRippleRef">@drawable/footer_button_ripple</item>
        <item name="goodButtonRippleRef">@drawable/footer_button_ripple</item>
        <item name="easyButtonRippleRef">@drawable/footer_button_ripple</item>
        <!-- Card Browser Colors -->
        <item name="cardBrowserDivider">@color/white</item>
        <!-- Browser colors -->
        <item name="suspendedColor">@color/material_grey_700</item>
        <item name="buriedColor">#612B09</item>
        <item name="markedColor">@color/material_deep_purple_400</item>
        <!-- Note editor colors -->
        <item name="duplicateColor">#855</item>
        <item name="editTextBackgroundColor">#EE5C5C5C</item>
        <!-- CFA fork: editor text-selection highlight was stock dark-blue; retone to
             the brand navy so selecting text in the editor stays on-brand (white
             text stays legible on navy). -->
        <item name="editTextHighlightColor">@color/cfa_navy</item>
        <item name="toolbarBackgroundColor">#616161</item>
        <item name="toolbarIconColor">@color/white</item>
        <item name="buttonShadowColor">#bdbdbd</item>
        <item name="buttonRippleColor">#BABABA</item>
        <item name="buttonForegroundColor">#757575</item>
        <!-- FAB / Study button — the single warm CFA accent, matching the light
             theme's branded FAB (was stock light-blue in dark mode, a glaring brand
             break vs the orange light-mode FAB). -->
        <item name="fab_normal">@color/cfa_accent</item>
        <item name="fab_pressed">@color/cfa_accent_hover</item>
        <!-- Images -->
        <item name="navDrawerImage">@drawable/nav_drawer_logo_dark_theme</item>
        <!-- Dialog styles -->
        <item name="android:listPreferredItemHeight">56dip</item>
        <item name="dialogCornerRadius">@dimen/dialog_corner_radius</item>
        <item name="android:dialogCornerRadius" tools:targetApi="p">@dimen/dialog_corner_radius</item>
        <item name="textAllCaps">false</item>
        <item name="clozeColor">#1976D2</item>
        <!--Custom Tabs colors-->
        <item name="customTabNavBarColor">@color/material_grey_800</item>
        <item name="popupBackgroundColor">@color/popup_background_theme_dark</item>
        <item name="editTextDisabled">@color/material_grey_500</item>
        <item name="overflowAndPopupMenuIconColor">#9effffff</item>
        <!-- StatusBar -->
        <item name="android:statusBarColor">@color/theme_dark_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Navbar -->
        <item name="android:navigationBarColor">@color/material_theme_grey</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        <item name="android:navigationBarColor">@color/black</item>

        <!-- Snackbar. Attributes snackbarStyle, snackbarTextViewStyle and snackbarButtonStyle
             must be *all* present in a theme (or its parent) in order for the snackbar
             to pick up the proper layout that uses these attributes. -->
        <item name="snackbarStyle">@style/SnackbarStyle</item>
        <item name="snackbarTextViewStyle">@style/Widget.MaterialComponents.Snackbar.TextView</item>
        <item name="snackbarButtonStyle">@style/SnackbarButtonStyle</item>
        <item name="snackbarBackgroundTintColor">#cfcfcf</item>
        <!-- CFA fork: snackbar action text sits on the LIGHT grey snackbar, so it
             needs a dark accent — retone from stock dark-blue to the brand navy
             (9.3:1 on #cfcfcf). -->
        <item name="snackbarButtonTextColor">@color/cfa_navy</item>

        <!-- Introduction -->
        <item name="introductionLogoTransparent">#883d3d3d</item>

        <!-- Widget styles -->
        <item name="switchPreferenceCompatStyle">@style/Preference.SwitchPreferenceCompat.Material3</item>
        <item name="sliderStyle">@style/SliderStyle</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.AnkiDroid</item>

        <!-- ProgressDialog-->
        <item name="dialogBackground">#ff303030</item>
        <!-- CFA fork: dialog action-button text sits on the dark #303030 dialog, so
             it needs a light accent — retone from stock light-blue to the warm
             brand accent-on-navy. -->
        <item name="progressDialogButtonTextColor">@color/cfa_accent_on_navy</item>

        <item name="checkMediaListBackground">@color/material_grey_700</item>
        <item name="checkMediaListForeground">@color/white</item>

        <!-- AlertDialogTheme-->
        <item name="alertDialogTheme">@style/ThemeOverlay.AnkiDroid.AlertDialog</item>
        <item name="tabStyle">@style/Widget.MaterialComponents.TabLayout</item>

        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.App.BottomSheetDialog</item>

        <item name="incrementerButtonBackground">@color/material_theme_grey</item>

        <!-- Reminder troubleshooting -->
        <item name="reminderTroubleshootingOk">@color/google_green_300</item>
        <item name="reminderTroubleshootingWarning">@color/google_yellow_300</item>
    </style>

    <style name="Theme_Dark" parent="Base.Theme.Dark"/>
</resources>
