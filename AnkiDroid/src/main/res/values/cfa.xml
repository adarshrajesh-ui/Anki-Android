    <!-- Ethics Minimal-Pairs study action (the flagship drill; mirrors the
         desktop Home's primary "Study Ethics — Minimal Pairs" CTA). -->
    <string name="cfa_study_ethics">Study Ethics — Minimal Pairs</string>
    <string name="cfa_study_ethics_empty">No CFA Ethics cards are available to study yet</string>
    <string name="cfa_study_ethics_deck">CFA Study — Ethics Minimal-Pairs</string>

    <!--
      CFA outlined-button style (Phase B M3-6 / M4-1 fix): the Material default
      outlined button inherits the theme's blue accent for its label + stroke,
      which reads as stock AnkiDroid on CFA screens. This reserves the CFA navy
      for the label/stroke and the warm accent for the ripple.
    -->
    <style name="Widget.Cfa.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/cfa_navy</item>
        <item name="strokeColor">@color/cfa_navy</item>
        <item name="rippleColor">@color/cfa_accent</item>
    </style>

    <!--
      CFA reviewer "Show answer" button theme (Phase B Pass-2 mobile Reviewer
      sweep). The legacy reviewer's flip button reused @style/HardButton, whose
      answerButtonBackground resolves to the stock blue-grey hardButtonBackground;
      when card animation is enabled the button is redrawn with footer_button_ripple,
      which reads answerButtonBackground from the view's own theme overlay. Applying
      this theme to the flip layout makes BOTH the static and the ripple path render
      the primary CTA in brand navy, without touching the Hard ease button.
    -->
    <style name="CfaShowAnswerButton">
        <item name="answerButtonBackground">@color/cfa_navy</item>
    </style>

</resources>
