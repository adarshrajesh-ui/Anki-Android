<!-- CFA fork: "Easy" ease fill retoned from the stock material_light_blue_500
     leak (the objective's flagged "ugly" stock-blue) to the CFA brand navy
     (cfa_ease_easy) — the "mastered / confident" tier. See values/cfa.xml. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android" >
    <item android:id="@+id/shape_background">
        <selector>
            <item android:state_pressed="true">
                <shape android:shape="rectangle" >
                    <solid android:color="@color/cfa_ease_easy_hover" />
                </shape>
            </item>
            <item android:state_focused="true">
                <shape android:shape="rectangle" >
                    <solid android:color="@color/cfa_ease_easy_hover" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle" >
                    <solid android:color="@color/cfa_ease_easy" />
                </shape>
            </item>
        </selector>
    </item>
</layer-list>
