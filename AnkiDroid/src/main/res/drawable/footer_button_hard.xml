<!-- CFA fork: "Hard" ease fill retoned from stock material_blue_grey to the CFA
     design-system neutral slate (cfa_ease_hard). See values/cfa.xml. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android" >
    <item android:id="@+id/shape_background">
        <selector>
            <item android:state_pressed="true">
                <shape android:shape="rectangle" >
                    <solid android:color="@color/cfa_ease_hard_hover" />
                </shape>
            </item>
            <item android:state_focused="true">
                <shape android:shape="rectangle" >
                    <solid android:color="@color/cfa_ease_hard_hover" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle" >
                    <solid android:color="@color/cfa_ease_hard" />
                </shape>
            </item>
        </selector>
    </item>
</layer-list>
