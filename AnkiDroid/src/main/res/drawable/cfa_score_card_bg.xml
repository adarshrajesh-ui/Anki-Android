<!--
  CFA fork: the shared score-card container for the Exam Readiness screen.
  A calm surface fill + hairline stroke + rounded corners so Memory /
  Performance / Readiness all read as consistent cards (Phase B M3-3 fix),
  mirroring the desktop CFA StatCard treatment.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/cfa_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/cfa_line" />
    <corners android:radius="12dp" />
</shape>
