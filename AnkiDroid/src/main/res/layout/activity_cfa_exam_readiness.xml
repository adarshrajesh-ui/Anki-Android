<!--
  CFA fork: the Exam Readiness hub. Branded CFA header + honest score cards
  (Memory / Performance / Readiness with ranges + give-up text) and per-topic
  recall. Populated by CfaExamReadinessActivity from the shared scoring engine
  (or the deterministic on-device fallback).
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CfaExamReadinessActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/cfa_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            android:background="@color/cfa_navy"
            android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
            app:titleTextColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ScrollView
            android:id="@+id/cfa_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/cfa_toolbar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Branded header band -->
                <TextView
                    android:id="@+id/cfa_eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANKICFA · CFA LEVEL II"
                    android:textColor="@color/cfa_accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/cfa_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/cfa_title_exam_readiness"
                    android:textColor="@color/cfa_ink"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/cfa_source"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/cfa_muted"
                    android:textSize="12sp"
                    tools:text="Source: on-device (deterministic)" />

                <!-- Honest score cards go here -->
                <LinearLayout
                    android:id="@+id/cfa_scores_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp" />

                <!-- Per-topic recall section -->
                <TextView
                    android:id="@+id/cfa_topics_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/cfa_readiness_per_topic"
                    android:textAllCaps="true"
                    android:textColor="@color/cfa_muted"
                    android:textSize="12sp"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/cfa_topics_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp" />

                <!-- Actions -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cfa_study_priority_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/cfa_study_by_priority"
                    android:backgroundTint="@color/cfa_navy"
                    android:textColor="@android:color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cfa_exam_config_button"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/cfa_exam_config_title" />

            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
