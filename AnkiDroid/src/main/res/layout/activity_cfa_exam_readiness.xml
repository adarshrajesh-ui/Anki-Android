<!--
  CFA fork: the Exam Readiness hub. Branded CFA toolbar + a full-bleed WebView
  that renders the shared self-contained readiness asset (assets/cfa/readiness.html),
  fed the learner's real honest scores + Bayesian verdict + per-topic recall by
  CfaExamReadinessActivity. The native CFA readiness screen, matching the desktop
  CfaReadinessPage (the same WebView-asset pattern as CFA Home + Concept Map).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cfa_surface"
    tools:context=".CfaExamReadinessActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/cfa_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="@color/cfa_navy"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
        app:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <WebView
        android:id="@+id/cfa_readiness_web"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/cfa_toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
