<!--
  CFA fork: exam configuration editor. Sets the CFA exam date, persisted under
  `cfa_exam_config` in col.conf (syncs natively). Branded CFA navy header.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cfa_night_bg"
    tools:context=".CfaExamConfigActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/cfa_config_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            android:background="@color/cfa_night_panel"
            android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
            app:titleTextColor="@color/cfa_night_ink"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@color/cfa_night_bg"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/cfa_config_toolbar"
            app:layout_constraintBottom_toTopOf="@id/cfa_bottom_nav"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cfa_brand_eyebrow"
                android:textColor="@color/cfa_gold_light"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/cfa_exam_config_date_label"
                android:textColor="@color/cfa_night_ink"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cfa_config_why"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/cfa_exam_config_why"
                android:textColor="@color/cfa_night_muted"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.15" />

            <!--
              Phase B Pass-3 (M-P3-3): this box looks like a filled input, so it
              MUST behave like one. It is the primary date control — tapping it
              opens the picker (a redundant "Pick date" button was removed). It is
              clickable/focusable with a ripple foreground and a >=48dp touch
              target (Material / WCAG 2.5.5), a trailing calendar affordance, and
              a screen-reader label set in the activity via
              examDateFieldContentDescription().
            -->
            <TextView
                android:id="@+id/cfa_config_date_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:minHeight="48dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="14dp"
                android:background="@color/cfa_night_panel_2"
                android:textColor="@color/cfa_night_ink"
                android:textSize="18sp"
                android:drawableEnd="@drawable/calendar_single_day"
                android:drawableTint="@color/cfa_gold"
                android:drawablePadding="12dp"
                tools:text="2026-08-22" />

            <TextView
                android:id="@+id/cfa_config_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/cfa_gold_light"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="49 days to the exam" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cfa_config_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/save"
                android:backgroundTint="@color/cfa_gold"
                android:textColor="@color/cfa_night_bg" />

        </LinearLayout>

        <include
            layout="@layout/cfa_bottom_shell"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
